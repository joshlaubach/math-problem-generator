# Math Learning Platform — API Environment Variables
# Copy this file to .env and fill in your real values.

# Anthropic Claude API
ANTHROPIC_API_KEY=
# Model used for all agents (override as needed; default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Database (shared with apps/web)
DATABASE_URL=postgresql://user:password@localhost:5432/math_platform

# Clerk Authentication (Phase 4)
# AUTH_PROVIDER: "jwt" (legacy, default) or "clerk" (production)
AUTH_PROVIDER=jwt
CLERK_SECRET_KEY=
# Clerk frontend API hostname, e.g. "your-instance.clerk.accounts.dev"
CLERK_FRONTEND_API=
# Optional: override JWKS URL directly (leave blank to derive from CLERK_FRONTEND_API)
CLERK_JWKS_URL=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# LLM provider ('anthropic' or 'openai' for fallback)
LLM_PROVIDER=anthropic

# OpenAI fallback (Phase 12: remove once Anthropic is stable)
OPENAI_API_KEY=

# Stripe — Session Credits (Phase: AI Tutor)
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TUTOR_SINGLE_PRICE_ID=    # $40 single session
STRIPE_TUTOR_3PACK_PRICE_ID=     # $99 for 3 sessions
STRIPE_TUTOR_5PACK_PRICE_ID=     # $149 for 5 sessions

# Voice — Deepgram STT (Phase 3)
# Get from https://console.deepgram.com
DEEPGRAM_API_KEY=

# Voice — ElevenLabs TTS (Phase 3)
# Get from https://elevenlabs.io/api
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=    # e.g. "21m00Tcm4TlvDq8ikWAM" (Rachel — clear, warm)

# Observability — Sentry error tracking
# Get DSN from https://sentry.io — leave blank to disable (dev/test safe)
SENTRY_DSN=

# Deployment environment ("development" | "staging" | "production")
ENVIRONMENT=development

# Teacher and Admin API keys (REQUIRED in production — fail-loud at startup if missing)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TEACHER_API_KEY=
ADMIN_API_KEY=

# Email — Resend transactional email (session summaries, parent links)
# Get from https://resend.com
RESEND_API_KEY=
