# Math Learning Platform — API Environment Variables
# Copy this file to .env and fill in your real values.

# Anthropic Claude API
ANTHROPIC_API_KEY=
# Model used for all agents (override as needed; default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Database (shared with apps/web)
DATABASE_URL=postgresql://user:password@localhost:5432/math_platform

# Clerk Authentication
CLERK_SECRET_KEY=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# LLM provider ('anthropic' or 'openai' for fallback)
LLM_PROVIDER=anthropic

# OpenAI fallback (Phase 12: remove once Anthropic is stable)
OPENAI_API_KEY=
